<UserControl x:Class="CmdMgr.Views.HistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="16,9">
            <TextBlock x:Name="CountText" DockPanel.Dock="Left" Text="No runs"
                       FontSize="12" Foreground="{StaticResource MutedBrush}"
                       VerticalAlignment="Center"/>
            <Button x:Name="RunAgainButton" DockPanel.Dock="Right" Content="▶ Run Again"
                    Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="12"
                    HorizontalAlignment="Right" Click="RunAgain_Click"/>
        </DockPanel>

        <Separator Grid.Row="1"/>

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="🕐" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="No Execution History" FontSize="14" FontWeight="Medium"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Completed runs will appear here." FontSize="12"
                       Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- History list -->
        <ScrollViewer x:Name="HistoryScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="16">
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Margin="0,0,0,10">
                            <Expander.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding StatusLabel}"
                                               FontWeight="Medium" FontSize="12"
                                               Foreground="{Binding StatusBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StartTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                               FontFamily="Consolas" FontSize="12"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Duration}"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="{StaticResource MutedBrush}"/>
                                </Grid>
                            </Expander.Header>
                            <Grid Margin="24,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Background="{StaticResource CardBrush}"
                                        CornerRadius="6" Padding="8"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        MaxHeight="220">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding OutputDisplay}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   TextWrapping="NoWrap"/>
                                    </ScrollViewer>
                                </Border>
                                <Button Grid.Row="1" Content="Copy Output"
                                        Style="{StaticResource ModernButton}"
                                        Padding="8,4" FontSize="11" Margin="0,6,0,0"
                                        HorizontalAlignment="Right"
                                        Click="CopyEntry_Click"
                                        Tag="{Binding}"
                                        Visibility="{Binding HasOutput,
                                            Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
