<Window x:Class="CmdMgr.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CmdMgr.ViewModels"
        xmlns:views="clr-namespace:CmdMgr.Views"
        Title="Command Manager" Height="680" Width="1040"
        MinWidth="760" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddCommandAction}"/>
        <KeyBinding Key="Return" Modifiers="Ctrl" Command="{Binding RunSelectedCommandAction}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="20,14,20,14" LastChildFill="False">
            <TextBlock Text="Command Manager" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <Button Content="＋ New Command"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddCommandAction}"
                    DockPanel.Dock="Right" HorizontalAlignment="Right"
                    Padding="16,8" FontSize="13" ToolTip="Ctrl+N"/>
            <ComboBox DockPanel.Dock="Right" Width="150" Margin="0,0,10,0"
                      ItemsSource="{Binding Filters}"
                      SelectedItem="{Binding CommandFilterValue}"
                      VerticalContentAlignment="Center">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource FilterDisplayNameConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0" Margin="16,0,16,10"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="10,7">
                    <DockPanel>
                        <TextBlock Text="🔍" DockPanel.Dock="Left" VerticalAlignment="Center"
                                   Margin="0,0,6,0" Foreground="{StaticResource MutedBrush}"/>
                        <Button DockPanel.Dock="Right"
                                Command="{Binding ClearSearchCommand}"
                                Style="{StaticResource ModernButton}"
                                BorderThickness="0" Padding="4,2"
                                Visibility="{Binding SearchText.Length,
                                    Converter={StaticResource CountToVisibilityConverter}}">
                            <TextBlock Text="✕" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                        </Button>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalAlignment="Center" FontSize="13"/>
                    </DockPanel>
                </Border>

                <Separator Grid.Row="1" Margin="0,0,0,4"/>

                <!-- Command list -->
                <ListBox Grid.Row="2" ItemsSource="{Binding FilteredCommands}"
                         SelectedItem="{Binding SelectedCommand}"
                         Style="{StaticResource SidebarListBox}"
                         Visibility="{Binding FilteredCommands.Count,
                             Converter={StaticResource CountToVisibilityConverter}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusIconConverter}}"
                                               FontSize="11" Width="16" VerticalAlignment="Center"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"/>
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="4,0,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="🖥" FontSize="10" Margin="6,0,0,0"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding IsLongRunning,
                                                   Converter={StaticResource BoolToVisibilityConverter}}"
                                               ToolTip="Long-running service"/>
                                </StackPanel>
                                <TextBlock Text="{Binding DisplayCommand}" FontSize="11"
                                           FontFamily="Consolas" Foreground="{StaticResource MutedBrush}"
                                           Margin="20,2,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource SidebarListBoxItem}">
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Run" Command="{Binding DataContext.RunCommandAction,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Show Output" Command="{Binding DataContext.ShowOutputCommandAction,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Show History" Command="{Binding DataContext.ShowHistoryCommandAction,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="Edit…" Command="{Binding DataContext.EditCommandAction,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Duplicate" Command="{Binding DataContext.DuplicateCommandAction,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="Delete…" Command="{Binding DataContext.DeleteCommandAction,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Empty state -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="20"
                            Visibility="{Binding FilteredCommands.Count,
                                Converter={StaticResource CountToVisibilityConverter},
                                ConverterParameter=invert, FallbackValue=Collapsed}">
                    <TextBlock Text="{Binding EmptyStateIcon}" FontSize="40"
                               HorizontalAlignment="Center" Margin="0,0,0,10"
                               Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock Text="{Binding EmptyStateTitle}" FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding EmptyStateHint}" FontSize="11"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,10"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                    <Button Content="New Command" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddCommandAction}" Padding="14,7"
                            Visibility="{Binding HasCommands,
                                Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- Detail pane -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Error banner -->
                <Border Grid.Row="0" Background="#FEE2E2" Padding="14,9"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="✕" Style="{StaticResource ModernButton}"
                                BorderThickness="0" Background="Transparent" Padding="4,2"
                                Command="{Binding DismissErrorCommand}"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                                   FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Selected command detail -->
                <views:CommandDetailView Grid.Row="1"
                    Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- No selection -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30"
                            Visibility="{Binding HasSelection,
                                Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                    <TextBlock Text="⌨" FontSize="44" HorizontalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding HasCommands,
                                   Converter={StaticResource BoolToStringConverter},
                                   ConverterParameter='Select a Command|Create Your First Command'}"
                               FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding HasCommands,
                                   Converter={StaticResource BoolToStringConverter},
                                   ConverterParameter='Choose a command from the list to view its output and history.|Save frequently used shell commands and run them without leaving the app.'}"
                               FontSize="12" Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="360" Margin="0,4,0,14"/>
                    <Button Content="New Command" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddCommandAction}" Padding="16,8"
                            Visibility="{Binding HasCommands,
                                Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
