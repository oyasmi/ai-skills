<UserControl x:Class="CmdMgr.Views.OutputPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- No process yet -->
        <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="📄" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="No Output Yet" FontSize="14" FontWeight="Medium"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Run this command to see its output here." FontSize="12"
                       Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"
                       Margin="0,4,0,14"/>
            <Button x:Name="RunFromEmptyButton" Content="Run Command"
                    Style="{StaticResource PrimaryButton}" Padding="16,8"
                    HorizontalAlignment="Center" Click="RunButton_Click"/>
        </StackPanel>

        <!-- Console -->
        <Grid x:Name="ConsoleRoot" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="14,9">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusIcon" FontSize="12" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText" Text="Running" FontSize="12" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <CheckBox x:Name="FollowCheck" Content="Follow" IsChecked="True"
                              VerticalAlignment="Center" Margin="0,0,14,0"
                              ToolTip="Keep the latest output visible"/>
                    <CheckBox x:Name="WrapCheck" Content="Wrap" IsChecked="True"
                              VerticalAlignment="Center" Margin="0,0,14,0"
                              Checked="WrapCheck_Changed" Unchecked="WrapCheck_Changed"
                              ToolTip="Wrap long lines"/>
                    <Button x:Name="CopyAllButton" Content="Copy All"
                            Style="{StaticResource ModernButton}"
                            Click="CopyAll_Click" Padding="10,4" FontSize="11"/>
                </StackPanel>
            </DockPanel>

            <Separator Grid.Row="1"/>

            <Grid Grid.Row="2">
                <TextBlock x:Name="WaitingText" Text="Waiting for output…"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="{StaticResource MutedBrush}"
                           Visibility="Collapsed"/>
                <TextBox x:Name="OutputBox"
                         IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12"
                         Padding="12" BorderThickness="0"
                         Background="{StaticResource SurfaceBrush}"
                         TextChanged="OutputBox_TextChanged"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
