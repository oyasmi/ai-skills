<Window x:Class="CmdMgr.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="History" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">

    <Grid>
        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="Collapsed">
            <TextBlock Text="🕐" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="No execution history" FontSize="14" FontWeight="Medium"
                       Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- History list -->
        <ScrollViewer x:Name="HistoryScroll" VerticalScrollBarVisibility="Auto" Padding="16">
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,16">
                            <!-- Header row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock x:Name="StatusIcon" FontSize="12" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding StartTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center"/>
                                <!-- Duration (hidden when null) -->
                                <TextBlock Text="{Binding Duration, StringFormat=' · {0}'}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding Duration,
                                               Converter={StaticResource NullToVisibilityConverter}}"/>
                                <TextBlock Text=" — " Foreground="{StaticResource MutedBrush}"
                                           FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusLabel" FontSize="12" FontWeight="Medium"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- Output -->
                            <Border Background="{StaticResource CardBrush}"
                                    CornerRadius="6" Padding="8"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <TextBox Text="{Binding Output, TargetNullValue='[No output captured]'}"
                                         IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0"
                                         FontFamily="Consolas" FontSize="11" Background="Transparent"
                                         MaxHeight="200" VerticalScrollBarVisibility="Auto"/>
                            </Border>
                        </StackPanel>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="success">
                                <Setter TargetName="StatusIcon" Property="Text" Value="✅"/>
                                <Setter TargetName="StatusLabel" Property="Text" Value="Success"/>
                                <Setter TargetName="StatusLabel" Property="Foreground" Value="#22C55E"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="failed">
                                <Setter TargetName="StatusIcon" Property="Text" Value="❌"/>
                                <Setter TargetName="StatusLabel" Property="Text" Value="Failed"/>
                                <Setter TargetName="StatusLabel" Property="Foreground" Value="#EF4444"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="terminated">
                                <Setter TargetName="StatusIcon" Property="Text" Value="⏹"/>
                                <Setter TargetName="StatusLabel" Property="Text" Value="Terminated"/>
                                <Setter TargetName="StatusLabel" Property="Foreground" Value="#F59E0B"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="running">
                                <Setter TargetName="StatusIcon" Property="Text" Value="🔵"/>
                                <Setter TargetName="StatusLabel" Property="Text" Value="Running"/>
                                <Setter TargetName="StatusLabel" Property="Foreground" Value="#3B82F6"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
