<Application x:Class="CmdMgr.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:CmdMgr.Views"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <views:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
            <views:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <views:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <views:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
            <views:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
            <views:FilterDisplayNameConverter x:Key="FilterDisplayNameConverter"/>
            <views:StatusDisplayNameConverter x:Key="StatusDisplayNameConverter"/>
            <views:StatusIconConverter x:Key="StatusIconConverter"/>
            <views:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
            <views:BoolToStringConverter x:Key="BoolToStringConverter"/>
            <views:RunButtonConverter x:Key="RunButtonConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
