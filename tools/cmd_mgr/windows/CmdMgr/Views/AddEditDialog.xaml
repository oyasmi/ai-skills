<Window x:Class="CmdMgr.Views.AddEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Command" Height="560" Width="560"
        MinHeight="480" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource SurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,18">
            <TextBlock x:Name="DialogTitle" Text="New Command" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Commands run with cmd.exe." FontSize="12"
                       Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Name -->
        <TextBlock Grid.Row="1" Text="Name" VerticalAlignment="Center"
                   Foreground="{StaticResource MutedBrush}" FontSize="12"/>
        <TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1"
                 Padding="8,6" FontSize="13" Margin="0,0,0,10"
                 TextChanged="Field_Changed"/>

        <!-- Command -->
        <TextBlock Grid.Row="2" Text="Command" VerticalAlignment="Top" Margin="0,6,0,0"
                   Foreground="{StaticResource MutedBrush}" FontSize="12"/>
        <TextBox x:Name="CommandBox" Grid.Row="2" Grid.Column="1"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12" Padding="8,6"
                 MinHeight="90" Margin="0,0,0,10"
                 TextChanged="Field_Changed"/>

        <!-- Working Directory -->
        <TextBlock Grid.Row="3" Text="Directory" VerticalAlignment="Center"
                   Foreground="{StaticResource MutedBrush}" FontSize="12"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Choose…"
                        Style="{StaticResource ModernButton}"
                        Click="Browse_Click" Padding="10,6" Margin="6,0,0,0"/>
                <TextBox x:Name="WorkingDirBox"
                         Padding="8,6" FontSize="12"
                         FontFamily="Consolas"
                         TextChanged="Field_Changed"/>
            </DockPanel>
            <TextBlock x:Name="DirectoryHint"
                       Text="Leave empty to inherit the app's working directory."
                       FontSize="11" Foreground="{StaticResource MutedBrush}"
                       Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Type -->
        <TextBlock Grid.Row="5" Text="Type" VerticalAlignment="Center"
                   Foreground="{StaticResource MutedBrush}" FontSize="12"/>
        <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="LongRunningRadio" Content="Long-running"
                             IsChecked="True" Margin="0,0,20,0" FontSize="13"
                             Checked="TypeRadio_Checked"/>
                <RadioButton x:Name="OneShotRadio" Content="One-shot" FontSize="13"
                             Checked="TypeRadio_Checked"/>
            </StackPanel>
            <TextBlock x:Name="TypeHint" FontSize="11" Foreground="{StaticResource MutedBrush}"
                       Margin="0,6,0,0" TextWrapping="Wrap"
                       Text="For servers and background processes. The command keeps running until you stop it."/>
        </StackPanel>

        <!-- Buttons -->
        <DockPanel Grid.Row="6" Grid.ColumnSpan="2" Margin="0,16,0,0">
            <TextBlock x:Name="ValidationHint" DockPanel.Dock="Left"
                       Text="Name and command are required." FontSize="11"
                       Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource ModernButton}"
                        Click="Cancel_Click" Padding="16,8" Margin="0,0,8,0" IsCancel="True"/>
                <Button x:Name="SaveButton" Content="Add Command" Style="{StaticResource PrimaryButton}"
                        Click="Save_Click" Padding="16,8" IsDefault="True"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
